---
import '../styles/global.css'
import { SearchBox } from '../components/SearchBox';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "日本語で使える GitHub Star 発見サイト" } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <link rel="icon" href="/starise/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/starise/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white">
    <header class="border-b border-border">
      <div class="mx-auto max-w-[1200px] px-4 py-4 flex items-center gap-4 flex-wrap">
        <a href={`${basePath}/`} class="text-xl font-bold text-text-primary hover:text-brand transition-colors duration-150 shrink-0">
          starise
        </a>
        <div class="flex-1 min-w-[200px] flex justify-end">
          <SearchBox basePath={basePath} client:idle />
        </div>
        <slot name="header-right" />
      </div>
    </header>
    <main class="mx-auto max-w-[1200px] px-4 py-8">
      <slot />
    </main>
    <footer class="border-t border-border mt-16">
      <div class="mx-auto max-w-[1200px] px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-text-muted text-xs">
        <span>starise — GitHub Star 発見サイト</span>
        <div class="flex items-center gap-4">
          <span>データソース: GitHub API</span>
          <a href="https://github.com/kotenbu135/starise" class="hover:text-brand transition-colors duration-150">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
