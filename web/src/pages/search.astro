---
import Layout from '../layouts/Layout.astro';
import { SearchResults } from '../components/SearchResults';

const q = Astro.url.searchParams.get('q') ?? '';
const basePath = import.meta.env.BASE_URL;
const title = q ? `「${q}」の検索結果 — starise` : '検索 — starise';
---

<Layout title={title}>
  <h1 class="text-2xl font-bold text-text-primary mb-6">リポジトリ検索</h1>
  <SearchResults initialQuery={q} basePath={basePath} client:load />
</Layout>
